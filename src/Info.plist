<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>Ametrine Launcher</string>
    <key>CFBundleExecutable</key>
    <string>AmetrineLauncher</string>
    <key>CFBundleIdentifier</key>
    <string>org.ametrinelauncher.launcher</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>AmetrineLauncher</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    
    <!-- Soporte para iPadOS unicamente (iPad M1/M2/M4 es el target principal) -->
    <key>UIDeviceFamily</key>
    <array>
        <integer>2</integer>
    </array>
    
    <!-- Orientaciones de pantalla soportadas -->
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    
    <!-- Soporte para Mandos Físicos de Consolas (GameController Framework) -->
    <key>GCSupportedGamepads</key>
    <array>
        <dict>
            <key>ProfileName</key>
            <string>ExtendedGamepad</string>
        </dict>
        <dict>
            <key>ProfileName</key>
            <string>MicroGamepad</string>
        </dict>
        <dict>
            <key>ProfileName</key>
            <string>DirectionalGamepad</string>
        </dict>
    </array>
    <key>GCSupportsControllerUserInteraction</key>
    <true/>
    
    <!-- Habilitar RAM Extendida en SideStore/TrollStore -->
    <key>com.apple.developer.kernel.extended-virtual-addressing</key>
    <true/>
    <key>com.apple.developer.increased-memory-limit</key>
    <true/>
    
    <!-- Configuración para compilación JIT inalámbrica y depuración -->
    <key>CSResourcesFileMapped</key>
    <true/>
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>
</dict>
</plist>
